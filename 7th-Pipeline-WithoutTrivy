pipeline {
agent any

```
tools {
    // Ensure SonarScanner is configured in Jenkins
    sonarQube 'sonar-scanner'
}

environment {
    IMAGE_NAME = "himanshurajak/devopsexamapp"
    IMAGE_TAG = "latest"
}

stages {

    stage('Git Checkout') {
        steps {
            echo "📦 Checking out source code..."
            git branch: 'master', url: 'https://github.com/Ayushmansen500/devops-exam-app.git'
        }
    }

    stage('File System Scan (Trivy)') {
        steps {
            echo "🔍 Running Trivy File System Scan..."
            sh '''
            trivy fs --scanners vuln,misconfig --format table -o trivy-fs-report.html .
            '''
        }
    }

    stage('SonarQube Analysis') {
        steps {
            echo "🧠 Running SonarQube Code Analysis..."
            withSonarQubeEnv('sonar') {
                sh '''
                sonar-scanner \
                  -Dsonar.projectName=devops-exam-app \
                  -Dsonar.projectKey=devops-exam-app \
                  -Dsonar.sources=. \
                  -Dsonar.python.version=3
                '''
            }
        }
    }

    stage('Verify Docker Compose') {
        steps {
            echo "🧩 Checking Docker Compose..."
            sh 'docker compose version'
        }
    }

    stage('Build Docker Image') {
        steps {
            dir('backend') {
                echo "🐳 Building Docker image..."
                sh '''
                docker build -t $IMAGE_NAME:$IMAGE_TAG .
                '''
            }
        }
    }

    stage('Push Docker Image') {
        steps {
            echo "📤 Pushing Docker image..."
            withDockerRegistry([credentialsId: 'dockerhub-creds', url: 'https://index.docker.io/v1/']) {
                sh '''
                docker push $IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }
    }

    stage('Deploy with Docker Compose') {
        steps {
            echo "🚀 Deploying application..."
            sh '''
            docker compose down || true
            docker compose up -d
            '''
        }
    }

    stage('Verify Deployment') {
        steps {
            echo "✅ Verifying deployment..."
            sh '''
            docker ps
            docker compose ps
            '''
        }
    }
}

post {
    always {
        echo "📋 Collecting logs..."
        sh 'docker compose logs --tail=50 || true'
        archiveArtifacts artifacts: 'trivy-fs-report.html', allowEmptyArchive: true
    }

    success {
        echo "🎉 Pipeline completed successfully!"
    }

    failure {
        echo "❌ Pipeline failed. Check logs above."
    }
}
```

}
